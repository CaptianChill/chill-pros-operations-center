rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userProfile() {
      return get(/databases/$(database)/documents/Users/$(request.auth.uid)).data;
    }

    function role() {
      return signedIn() && exists(/databases/$(database)/documents/Users/$(request.auth.uid))
        ? userProfile().role
        : null;
    }

    function isOwner() {
      return signedIn() && (role() == 'owner' || request.auth.token.email == 'chillprostx@gmail.com');
    }

    function isOffice() {
      return signedIn() && role() == 'office';
    }

    function isTechnician() {
      return signedIn() && role() == 'technician';
    }

    match /Users/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isOwner());
      allow create, update, delete: if isOwner();
    }

    match /Customers/{customerId} {
      allow read: if signedIn();
      allow create, update: if isOwner() || isOffice() || isTechnician();
      allow delete: if isOwner() || isOffice();
    }

    match /Technicians/{technicianId} {
      allow read: if signedIn();
      allow create, update, delete: if isOwner() || isOffice();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
